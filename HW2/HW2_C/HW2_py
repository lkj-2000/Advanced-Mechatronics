import time
import board
import pwmio


pwm = pwmio.PWMOut(board.GP18, frequency = 50)

def set_angle(angle):
    pwm.duty_cycle = int((angle / 180) * 65535)

while True:
    for angle in range(0,180,1):
        set_angle(angle)
        time.sleep(1)
    for angle in range(180,0,-1):
        set_angle(angle)
        time.sleep(1)